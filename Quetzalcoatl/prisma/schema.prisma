generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Project {
  id          String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug        String        @unique
  name        String
  description String?
  status      String        @default("ativo")
  aiSummary   String?       @map("ai_summary")
  memories    Memory[]
  inboxItems  InboxItem[]
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  @@map("projects")
}

model Memory {
  id          String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId   String          @map("project_id") @db.Uuid
  project     Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  type        String
  title       String
  content     String
  status      String          @default("vigente")
  priority    String          @default("media")
  tags        String[]        @default([])
  source      String?
  confidence  String          @default("alta")
  metadata    Json            @default("{}")
  versions    MemoryVersion[]
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  @@index([projectId], map: "idx_memories_project_id")
  @@index([type], map: "idx_memories_type")
  @@index([status], map: "idx_memories_status")
  @@index([priority], map: "idx_memories_priority")
  @@map("memories")
}

model MemoryVersion {
  id        String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  memoryId  String         @map("memory_id") @db.Uuid
  memory    Memory         @relation(fields: [memoryId], references: [id], onDelete: Cascade)
  title     String
  content   String
  status    String
  priority  String
  tags      String[]       @default([])
  createdAt DateTime       @default(now()) @map("created_at")

  @@index([memoryId], map: "idx_memory_versions_memory_id")
  @@map("memory_versions")
}

model InboxItem {
  id                 String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  rawContent         String      @map("raw_content")
  suggestedProjectId String?     @map("suggested_project_id") @db.Uuid
  suggestedProject   Project?    @relation(fields: [suggestedProjectId], references: [id])
  suggestedType      String?     @map("suggested_type")
  status             String      @default("pendente")
  source             String?
  createdAt          DateTime    @default(now()) @map("created_at")

  @@map("inbox_items")
}
