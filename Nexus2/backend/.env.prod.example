# Nexus API - Production Environment
# Copie para .env e ajuste as variáveis

# Banco de dados (PostgreSQL)
DATABASE_URL=postgresql://nexus:SUA_SENHA_AQUI@postgres:5432/nexus
# Ou separado:
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=nexus
DB_USERNAME=nexus
DB_PASSWORD=SUA_SENHA_AQUI

# JWT (Gere com: openssl rand -hex 64)
JWT_SECRET=SECRETO_MUITO_FORTE_TROQUE_ISSO
JWT_EXPIRES_IN=15m

# API
API_PORT=4001
FRONTEND_URL=https://seu-dominio.com
NODE_ENV=production
LOG_LEVEL=warn

# n8n Integration
N8N_BASE_URL=http://n8n:5678
N8N_WORKFLOW_INGESTION_ID=a0be15a0-f2b4-4636-ac2e-6ff9539f49d9
# N8N_API_KEY=sua_chave_api_n8n (se necessário)

# Métricas RAG
METRICS_WEBHOOK_TOKEN=gerar-com-openssl-rand-hex-32
